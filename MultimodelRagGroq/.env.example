# P0 — required (app crashes loudly if these are missing or placeholders)
GROQ_API_KEY=your_groq_api_key_here
DATABASE_URL=postgresql://geminirag:geminirag@localhost:5432/geminirag
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change_me_to_a_long_random_string

# P1 — LLM provider (set to "gemini" to use Google Gemini for all LLM/embed calls)
# Switching from "groq" to "gemini" changes embedding dimensions — re-ingest required.
LLM_PROVIDER=groq

# Groq models (used when LLM_PROVIDER=groq)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_PROCESSING_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Gemini (used when LLM_PROVIDER=gemini or for ADK agent)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# P2 — defaults provided
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=geminirag_chunks

ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

UPLOAD_DIR=/tmp/geminirag_uploads

CHUNK_SIZE=600
CHILD_CHUNK_SIZE=150
CHUNK_OVERLAP=50
RAG_TOP_K=6
CONFIDENCE_THRESHOLD=0.35

CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF=60

OTEL_EXPORTER=stdout
OTEL_SERVICE_NAME=geminirag

GEMINIRAG_RERANKER=1

# P3 — production overrides
ALLOWED_ORIGINS=http://localhost:5173
