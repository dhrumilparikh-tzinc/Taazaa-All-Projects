# Copy this file to `.env` and paste your real Groq API key.
# Never commit the real .env file.
# Get your free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional — model name. Default is llama-3.3-70b-versatile.
# Other options: llama3-70b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Optional — max retries per agent when validation fails. Default 2.
MAX_AGENT_RETRIES=2

# Optional — also stream logs to stdout. Set to 0 to disable.
LOG_TO_CONSOLE=1
