# ── P0 — required (app crashes loudly if these are missing or placeholders) ───
GEMINI_API_KEY=your_gemini_api_key_here
DATABASE_URL=postgresql://geminirag:geminirag@localhost:5432/geminirag
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change_me_to_a_long_random_string

# ── Gemini models ──────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=geminirag_chunks

# ── File storage ───────────────────────────────────────────────────────────────
UPLOAD_DIR=C:/tmp/geminirag_uploads

# ── RAG tuning ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=600
CHILD_CHUNK_SIZE=150
CHUNK_OVERLAP=50
RAG_TOP_K=8
CONFIDENCE_THRESHOLD=0.35

# ── Auth ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF=60

# ── Observability ──────────────────────────────────────────────────────────────
OTEL_EXPORTER=stdout
OTEL_SERVICE_NAME=geminirag

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
